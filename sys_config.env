# Per-machine environment settings for this mining system.
# Set these before running sage.py (or export them in your shell / run.bat).
#
# VPN behaviour:
#   USE_VPN_ROTATOR=1   → pause/resume with vpn_rotator.py running in another terminal (default)
#   USE_VPN_ROTATOR=0   → change VPN only when IP block detected (no rotator needed)
#
# Captcha recovery:
#   CAPTCHA_RECOVERY_MODE=click    → auto-click captcha (default)
#   CAPTCHA_RECOVERY_MODE=restart  → restart the script on captcha

USE_VPN_ROTATOR=1
CAPTCHA_RECOVERY_MODE=click
